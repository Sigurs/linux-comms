{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "./src",
    "lib": ["ES2022"]
  },
  "include": [
    "src/main/**/*",
    "src/preload/**/*",
    "src/providers/**/*",
    "src/shared/**/*"
  ],
  "exclude": [
    "src/renderer/**/*"
  ]
}
