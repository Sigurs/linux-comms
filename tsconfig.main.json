{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "node16",
    "outDir": "./dist",
    "rootDir": "./src",
    "lib": ["ES2022"]
  },
  "include": ["src/main/**/*", "src/preload/**/*", "src/providers/**/*", "src/shared/**/*"],
  "exclude": ["src/renderer/**/*"]
}
